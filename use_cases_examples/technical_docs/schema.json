{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "frontmatter": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 5,
          "maxLength": 100
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version (e.g., 1.2.3)"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "ISO date format (YYYY-MM-DD)"
        },
        "author": {
          "type": "string",
          "minLength": 2
        },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "published"]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "required": ["title", "version", "date", "author", "status"]
    },
    "sections": {
      "type": "object",
      "properties": {
        "overview": {
          "type": "object",
          "properties": {
            "content": {"type": "string"},
            "subsections": {"type": "object"}
          }
        },
        "api-reference": {
          "type": "object",
          "properties": {
            "content": {"type": "string"},
            "subsections": {
              "type": "object",
              "properties": {
                "endpoints": {
                  "type": "object",
                  "properties": {
                    "content": {"type": "string"}
                  }
                },
                "authentication": {
                  "type": "object",
                  "properties": {
                    "content": {"type": "string"}
                  }
                },
                "rate-limiting": {
                  "type": "object",
                  "properties": {
                    "content": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "examples": {
          "type": "object",
          "properties": {
            "content": {"type": "string"},
            "subsections": {
              "type": "object",
              "properties": {
                "basic-usage": {
                  "type": "object",
                  "properties": {
                    "content": {"type": "string"}
                  }
                },
                "advanced-usage": {
                  "type": "object",
                  "properties": {
                    "content": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "changelog": {
          "type": "object",
          "properties": {
            "content": {"type": "string"}
          }
        }
      },
      "required": ["overview", "api-reference", "examples"]
    }
  },
  "required": ["frontmatter", "sections"]
}