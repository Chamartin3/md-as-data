#!/usr/bin/env bash
# refdb CLI Wrapper
# Add this script to your PATH to run refdb from anywhere

# Get the directory where this script is located
SCRIPT_DIR="$(builtin cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Project root is one level up from bin/
PROJECT_ROOT="$(builtin cd "$SCRIPT_DIR/.." && pwd)"

# Run refdb using uv with --project to specify the project root
# This preserves the current working directory for file operations
exec uv run --project "$PROJECT_ROOT" mddata "$@"
